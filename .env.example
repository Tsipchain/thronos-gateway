# =============================================================================
# THRONOS GATEWAY — Payment & Service Orchestration
# =============================================================================

# App
NODE_ENV=production
PORT=3000
GATEWAY_SECRET=REPLACE_WITH_SECURE_RANDOM_64_HEX

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/thronos_gateway

# Redis (Queue + Cache)
REDIS_URL=redis://default:PASSWORD@redis.railway.internal:6379

# Stripe
STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# Thronos Core Node
THRONOS_CORE_URL=https://api.thronoschain.org
THRONOS_INTERNAL_KEY=thr_ai_REPLACE

# Treasury Wallets
THR_TREASURY_ADDRESS=REPLACE_WITH_THR_TREASURY
ETH_TREASURY_ADDRESS=REPLACE_WITH_ETH_TREASURY
BSC_TREASURY_ADDRESS=REPLACE_WITH_BSC_TREASURY

# EVM RPC Endpoints
ETH_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Payment Config
PAYMENT_CONFIRMATION_BLOCKS=12
MIN_PAYMENT_USD=1.00
MAX_PAYMENT_USD=50000.00

# Fee Split (percentages)
FEE_TREASURY_PCT=50
FEE_BURN_PCT=25
FEE_LP_PCT=25

# JWT
JWT_SECRET=REPLACE_WITH_SECURE_JWT_SECRET
JWT_EXPIRY=24h

# Ecosystem Services
COMMERCE_URL=https://commerce.thronoschain.org
BUILDER_URL=https://builder.thronoschain.org
VERIFYID_URL=https://verifyid.thronoschain.org
SENTINEL_URL=https://sentinel.thronoschain.org
BTC_ADAPTER_URL=https://btc-api.thronoschain.org
